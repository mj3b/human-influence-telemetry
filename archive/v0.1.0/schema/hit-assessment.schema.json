{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mj3b/human-influence-telemetry/blob/main/schema/hit-assessment.schema.json",
  "title": "Human Influence Telemetry Assessment",
  "description": "Machine-readable assessment of substantive human influence in one AI-mediated institutional decision process.",
  "type": "object",
  "additionalProperties": false,
  "required": ["assessment_id","schema_version","institutional_unit","decision_process","period","sampling_rule","assessor","substantive_findings","telemetry_integrity","limitations"],
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id","artifact_type","citation","provenance_status"],
      "properties": {
        "artifact_id": {"type":"string","minLength":1},
        "artifact_type": {"type":"string","minLength":1},
        "citation": {"type":"string","minLength":1},
        "provenance_status": {"type":"string","enum":["verified","partially_verified","unverified","not_produced"]},
        "notes": {"type":"string"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension","finding","supporting_artifacts","requested_missing_artifacts","rationale"],
      "properties": {
        "dimension": {"type":"string","enum":["counsel","judgment","command","correction","repair","reform"]},
        "finding": {"oneOf":[{"type":"integer","enum":[0,1,2]},{"const":"IE"}]},
        "supporting_artifacts": {"type":"array","items":{"$ref":"#/$defs/artifact"}},
        "requested_missing_artifacts": {"type":"array","items":{"type":"string"}},
        "rationale": {"type":"string","minLength":20},
        "ambiguity_note": {"type":["string","null"]}
      }
    },
    "integrityFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status","provenance","completeness","edit_authority","independence","tamper_evidence","retention","rationale"],
      "properties": {
        "status": {"type":"string","enum":["adequate","limited","unreliable","IE"]},
        "provenance": {"type":"string"},
        "completeness": {"type":"string"},
        "edit_authority": {"type":"string"},
        "independence": {"type":"string"},
        "tamper_evidence": {"type":"string"},
        "retention": {"type":"string"},
        "rationale": {"type":"string","minLength":20}
      }
    }
  },
  "properties": {
    "assessment_id": {"type":"string","pattern":"^HIT-[A-Za-z0-9._-]+$"},
    "schema_version": {"type":"string","const":"0.1.0"},
    "institutional_unit": {"type":"string","minLength":2},
    "decision_process": {"type":"string","minLength":10},
    "period": {"type":"object","additionalProperties":false,"required":["start","end"],"properties":{"start":{"type":"string","format":"date"},"end":{"type":"string","format":"date"}}},
    "sampling_rule": {"type":"string","minLength":10},
    "assessor": {"type":"object","additionalProperties":false,"required":["name","assessment_date"],"properties":{"name":{"type":"string","minLength":2},"organization":{"type":["string","null"]},"assessment_date":{"type":"string","format":"date"}}},
    "substantive_findings": {"type":"array","minItems":6,"maxItems":6,"items":{"$ref":"#/$defs/finding"}},
    "telemetry_integrity": {"$ref":"#/$defs/integrityFinding"},
    "summary": {"type":"string"},
    "limitations": {"type":"array","minItems":1,"items":{"type":"string"}}
  }
}
